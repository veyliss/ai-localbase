# AI LocalBase Docker runtime configuration
#
# 使用方式：
#   1. 复制本文件为本地配置文件：
#      cp .env.example .env
#   2. 按你的模型、端口、数据目录修改 .env。
#   3. 启动开发环境：
#      docker compose -f docker-compose.dev.yml up -d --build
#
# 说明：
#   - Docker Compose 会自动读取项目根目录的 .env。
#   - .env 已在 .gitignore 中忽略，不应提交真实密钥或本机路径。
#   - 本文件只保存可公开的示例值和注释。


# -----------------------------------------------------------------------------
# 端口配置
# -----------------------------------------------------------------------------

# 后端 HTTP 端口。前端、健康检查和 OpenAI compatible API 都会访问这个端口。
PORT=8080

# 前端 Web 端口。浏览器默认打开 http://localhost:4173。
FRONTEND_PORT=4173

# Qdrant HTTP API 端口。一般保持 6333。
QDRANT_HTTP_PORT=6333

# Qdrant gRPC 端口。当前项目主要使用 HTTP，但保留 gRPC 端口便于调试。
QDRANT_GRPC_PORT=6334


# -----------------------------------------------------------------------------
# 认证配置
# -----------------------------------------------------------------------------

# 是否启用认证。默认关闭（本地开发）。
ENABLE_AUTH=false

# 登录账户名。默认 root。
AUTH_USERNAME=root

# 登录密码。设置后首次启动会自动创建 root 用户并保存 bcrypt 哈希。
# 若留空，则 ENABLE_AUTH=true 时进入首次初始化向导。
# 生产环境建议使用强密码（16+ 字符）。
AUTH_PASSWORD=

# 首次初始化保护 Token。可选；设置后初始化向导必须输入该 Token。
# 生产环境若不使用 AUTH_PASSWORD 自动初始化，建议设置。
# 可通过以下命令生成：
#   openssl rand -base64 32
AUTH_SETUP_TOKEN=

# root 密码一次性重置。仅在已有 root 用户时生效，必须两个变量同时设置。
# 重置成功后会撤销所有 Web 会话；确认可登录后应删除这两个变量并重启。
# AUTH_RESET_TOKEN 会以哈希形式记录，同一个 Token 只执行一次。
AUTH_RESET_TOKEN=
AUTH_RESET_PASSWORD=

# 旧版 JWT 配置兼容项。当前认证使用服务端 session，不再要求设置。
JWT_SECRET=

# -----------------------------------------------------------------------------
# 后端本地数据路径
# -----------------------------------------------------------------------------

# 上传文件保存目录。
# Docker dev/app/prod compose 中建议保持 /app/data/uploads。
UPLOAD_DIR=/app/data/uploads

# 应用状态文件，保存知识库、文档、模型配置等状态。
STATE_FILE=/app/data/app-state.json

# 聊天记录 SQLite 文件。
CHAT_HISTORY_FILE=/app/data/chat-history.db


# -----------------------------------------------------------------------------
# Qdrant 向量数据库配置
# -----------------------------------------------------------------------------

# 后端容器访问 Qdrant 的地址。
# 在 Docker Compose 网络内使用服务名 qdrant；本机直连时可改为 http://localhost:6333。
QDRANT_URL=http://qdrant:6333

# Qdrant API Key。默认本地 Qdrant 不需要，托管/受保护实例再填写。
QDRANT_API_KEY=

# Qdrant collection 前缀。
# 实际 collection 名通常是：${QDRANT_COLLECTION_PREFIX}${knowledgeBaseId}
# 例如前缀 kb_ + 知识库 kb-1 => kb_kb-1。
#
# 重要：
#   同一个 Qdrant collection 不能混用不同向量维度。
#   如果从 1024 维模型切换到 768 维模型，建议改一个新前缀，
#   例如 QDRANT_COLLECTION_PREFIX=kb_768_，然后重建索引。
QDRANT_COLLECTION_PREFIX=kb_

# 向量维度，必须与 Embedding 模型输出维度一致。
# 常见示例：
#   nomic-embed-text: 768
#   bge-m3: 1024
#   text-embedding-3-small: 1536
#
# 如果这里与已存在 collection 的维度不一致，会出现：
#   Vector dimension error: expected dim: 1024, got 768
QDRANT_VECTOR_SIZE=768

# Qdrant 距离算法。常用 Cosine。
QDRANT_DISTANCE=Cosine

# 后端请求 Qdrant 的超时时间，单位秒。
QDRANT_TIMEOUT_SECONDS=5

# Qdrant 持久化目录。默认保存在项目根目录 qdrant_storage。
QDRANT_STORAGE_PATH=./qdrant_storage


# -----------------------------------------------------------------------------
# 模型服务配置
# -----------------------------------------------------------------------------

# Ollama 地址。
# macOS / Windows Docker Desktop：通常使用 http://host.docker.internal:11434
# Linux 原生 Docker：可按实际网络改为宿主机 IP，或使用 host 网络方案。
OLLAMA_BASE_URL=http://host.docker.internal:11434


# -----------------------------------------------------------------------------
# RAG 高级能力开关
# -----------------------------------------------------------------------------

# Hybrid Search：dense + sparse 混合召回。默认关闭，建议有评估基线后再开启。
#
# 重要：
#   当前 Hybrid Search 会优先使用 Qdrant named dense/sparse vectors。
#   如果你已有旧 collection（只有匿名 dense vector），开启前建议：
#     1. 修改 QDRANT_COLLECTION_PREFIX 为新前缀，例如 kb_hybrid_768_
#     2. 重启服务
#     3. 重新导入或重建知识库索引
#   否则系统会回退到兼容旧 collection 的 dense 检索，无法完整发挥 sparse 召回效果。
ENABLE_HYBRID_SEARCH=false

# Semantic Reranker：语义重排启动默认值。默认关闭，可能增加检索延迟。
# 启动后仍可在前端“高级检索”中切换关键词融合 / 语义重排策略。
ENABLE_SEMANTIC_RERANKER=false

# Query Rewrite：查询改写/扩展启动默认值。默认关闭，可能增加 LLM 调用成本和延迟。
# 启动后仍可在前端“高级检索”中开关，并配置最多 1-5 个改写查询。
ENABLE_QUERY_REWRITE=false

# Semantic Cache：语义相似缓存。默认关闭，适合重复查询较多的场景。
ENABLE_SEMANTIC_CACHE=false

# Context Compression：上下文压缩。默认关闭，适合长上下文但会增加一次 LLM 调用。
ENABLE_CONTEXT_COMPRESSION=false


# -----------------------------------------------------------------------------
# 检索参数
# -----------------------------------------------------------------------------

# 单文档问答最终返回 chunk 数。
RETRIEVAL_TOPK_DOCUMENT=6

# 单文档问答候选召回 chunk 数，通常应大于最终返回数。
RETRIEVAL_CANDIDATE_TOPK_DOCUMENT=12

# 知识库范围问答最终返回 chunk 数。
RETRIEVAL_TOPK_KNOWLEDGE_BASE=10

# 知识库范围问答候选召回 chunk 数。
RETRIEVAL_CANDIDATE_TOPK_ALL_DOCS=32

# 知识库范围下，每个文档最多进入最终上下文的 chunk 数。
# 用于避免单一文档占满上下文。
RETRIEVAL_MAX_CHUNKS_PER_DOCUMENT=2

# 构建 prompt 时允许的最大检索上下文字数。
RETRIEVAL_MAX_CONTEXT_CHARS=2400

# 是否在低置信度时自动扩大召回。
RETRIEVAL_ENABLE_AUTO_EXPAND=false


# -----------------------------------------------------------------------------
# MCP 配置
# -----------------------------------------------------------------------------

# 是否启用内置 MCP Server。
ENABLE_MCP=true

# MCP HTTP 挂载路径。
MCP_BASE_PATH=/mcp

# MCP 单次请求超时，单位秒。
MCP_REQUEST_TIMEOUT_SECONDS=15

# MCP 每分钟请求限流。
MCP_REQUESTS_PER_MINUTE=120


# -----------------------------------------------------------------------------
# 前端配置
# -----------------------------------------------------------------------------

# 浏览器访问后端 API 的地址。
# dev 模式下 Vite 会代理相对请求，但保留该值用于构建/部署场景。
VITE_API_BASE_URL=http://localhost:8080

# Vite dev server 在容器内代理到后端服务的地址。
# 仅 docker-compose.dev.yml 使用。
VITE_DEV_PROXY_TARGET=http://backend:8080
